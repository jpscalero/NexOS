#!/bin/bash
# Aggressive cleanup for size reduction
set -e

echo "Performing aggressive cleanup..."

# 1. Clean APT cache
apt-get clean
rm -rf /var/cache/apt/archives/*

# 2. Remove documentation and manpages
rm -rf /usr/share/doc/*
rm -rf /usr/share/man/*
rm -rf /usr/share/info/*
rm -rf /usr/share/help/*

# 3. Remove locale files (keep only es and en)
find /usr/share/locale/ -maxdepth 1 -mindepth 1 -not -name 'es*' -not -name 'en*' -exec rm -rf {} +

echo "Cleanup complete."
