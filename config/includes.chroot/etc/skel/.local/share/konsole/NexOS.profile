[General]
Command=/bin/bash
Icon=utilities-terminal
Name=NexOS
Parent=FALLBACK/
TerminalColumns=120
TerminalRows=36

[Appearance]
ColorScheme=BreezeDark
Font=Hack,12,-1,5,50,0,0,0,0,0

[Interaction Options]
AutoCopySelectedText=true
TrimLeadingSpacesInSelectedText=true
TrimTrailingSpacesInSelectedText=true
UnderlineLinksEnabled=true

[Scrolling]
HistoryMode=2
HistorySize=10000
ScrollBarPosition=2

[Terminal Features]
BlinkingCursorEnabled=true
